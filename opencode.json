{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "brave-search": {
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server",
        "--transport",
        "http"
      ],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "type": "local"
    },
    "knowns": {
      "command": [
        "npx",
        "-y",
        "knowns",
        "mcp",
        "--stdio"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}
