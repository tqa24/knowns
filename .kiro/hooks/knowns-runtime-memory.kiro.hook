{
  "description": "Inject bounded Knowns memory when the session starts.",
  "enabled": true,
  "name": "Knowns runtime memory",
  "then": {
    "command": "knowns runtime-memory hook --runtime kiro --event promptsubmit",
    "type": "runCommand"
  },
  "version": "1.0.0",
  "when": {
    "type": "promptSubmit"
  }
}
